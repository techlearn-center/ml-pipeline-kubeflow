# =============================================================================
# ML Pipeline with Kubeflow -- Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# =============================================================================

# -- Kubeflow Pipelines -------------------------------------------------------
KFP_ENDPOINT=http://localhost:8080
KFP_NAMESPACE=kubeflow

# -- MinIO (S3-compatible artifact store) -------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=kfp-artifacts

# -- MySQL (KFP metadata store) ----------------------------------------------
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=kfp_metadata
MYSQL_USER=kfp
MYSQL_PASSWORD=kfppassword

# -- MLflow tracking ----------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=kfp-training-pipeline

# -- Google Cloud (optional, for Vertex AI) -----------------------------------
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCP_PROJECT_ID=my-gcp-project
# GCP_REGION=us-central1

# -- Pipeline configuration ---------------------------------------------------
PIPELINE_NAME=training-pipeline
MODEL_NAME=sklearn-classifier
TRAIN_TEST_SPLIT=0.2
RANDOM_SEED=42
